  grp_code_id Int
  group       TbCmCodeGroup @relation(fields: [grp_code_id], references: [grp_code_id], onDelete: Cascade)

  @@unique([grp_code_id, cm_code])
  @@index([prjct_id])
  @@index([grp_code_id])
  @@map("tb_cm_code")
}

