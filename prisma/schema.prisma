generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model TbCmMember {
  mber_id             String                    @id @default(uuid())
  email_addr          String?                   @unique
  pswd_hash           String?
  mber_nm             String?
  profl_img_url       String?
  mber_sttus_code     String                    @default("UNVERIFIED")
  join_dt             DateTime                  @default(now())
  mdfcn_dt            DateTime?
  wthdrw_dt           DateTime?
  accountLocks        TbCmAccountLock[]
  emailVerifications  TbCmEmailVerification[]
  loginAttempts       TbCmLoginAttempt[]
  memberSessions      TbCmMemberSession[]
  passwordResetTokens TbCmPasswordResetToken[]
  refreshTokens       TbCmRefreshToken[]
  socialAccounts      TbCmSocialAccount[]
  removalNotices      TbPjMemberRemovalNotice[]
  projectMembers      TbPjProjectMember[]
  settingsHistory     TbPjSettingsHistory[]

  @@map("tb_cm_member")
}

model TbCmEmailVerification {
  vrfctn_id         String     @id @default(uuid())
  mber_id           String
  email_addr        String
  vrfctn_token_val  String     @unique
  vrfctn_ty_code    String     @default("REGISTER")
  vrfctn_sttus_code String     @default("PENDING")
  expiry_dt         DateTime
  vrfctn_dt         DateTime?
  creat_dt          DateTime   @default(now())
  member            TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_email_verification")
}

model TbCmRefreshToken {
  token_id       String     @id @default(uuid())
  mber_id        String
  token_hash_val String     @unique
  auto_login_yn  String     @default("N")
  expiry_dt      DateTime
  creat_dt       DateTime   @default(now())
  revoked_dt     DateTime?
  sesn_id        String?
  member         TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_refresh_token")
}

model TbCmLoginAttempt {
  attempt_id      String     @id @default(uuid())
  mber_id         String
  attempt_ip_addr String?
  succes_yn       String     @default("N")
  fail_rsn_cn     String?
  creat_dt        DateTime   @default(now())
  member          TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_login_attempt")
}

model TbCmAccountLock {
  lock_id                String     @id @default(uuid())
  mber_id                String
  lock_rsn_cn            String?
  fail_cnt               Int        @default(0)
  lock_expiry_dt         DateTime?
  unlock_token_val       String?    @unique
  unlock_token_expiry_dt DateTime?
  lock_sttus_code        String     @default("LOCKED")
  creat_dt               DateTime   @default(now())
  unlocked_dt            DateTime?
  member                 TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_account_lock")
}

model TbCmMemberSession {
  sesn_id        String     @id @default(uuid())
  mber_id        String
  device_info_cn String?
  ip_addr        String?
  creat_dt       DateTime   @default(now())
  last_acces_dt  DateTime?
  invald_dt      DateTime?
  member         TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_member_session")
}

model TbCmPasswordResetToken {
  reset_token_id   String     @id @default(uuid())
  mber_id          String
  token_val        String     @unique
  token_sttus_code String     @default("PENDING")
  expiry_dt        DateTime
  use_dt           DateTime?
  creat_dt         DateTime   @default(now())
  member           TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_password_reset_token")
}

model TbCmSocialAccount {
  social_acnt_id    String     @id @default(uuid())
  mber_id           String
  provdr_code       String
  provdr_user_id    String
  provdr_email_addr String?
  creat_dt          DateTime   @default(now())
  member            TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@unique([provdr_code, provdr_user_id])
  @@map("tb_cm_social_account")
}

model TbPjProject {
  prjct_id        String                  @id @default(uuid())
  prjct_nm        String
  prjct_dc        String?
  client_nm       String?
  bgng_de         DateTime?
  end_de          DateTime?
  creat_mber_id   String?
  creat_dt        DateTime                @default(now())
  mdfcn_dt        DateTime?
  apiKeys         TbPjProjectApiKey[]
  invitations     TbPjProjectInvitation[]
  members         TbPjProjectMember[]
  settings        TbPjProjectSettings?
  settingsHistory TbPjSettingsHistory[]

  @@map("tb_pj_project")
}

model TbPjProjectSettings {
  seting_id         String      @id @default(uuid())
  prjct_id          String      @unique
  ai_call_mthd_code String      @default("DIRECT")
  plan_code         String      @default("FREE")
  creat_dt          DateTime    @default(now())
  mdfcn_dt          DateTime    @default(now())
  project           TbPjProject @relation(fields: [prjct_id], references: [prjct_id])

  @@map("tb_pj_project_settings")
}

model TbPjProjectInvitation {
  invt_id         String      @id @default(uuid())
  prjct_id        String
  email_addr      String
  role_code       String      @default("MEMBER")
  invt_token_val  String      @unique
  invtr_mber_id   String?
  invt_sttus_code String      @default("PENDING")
  invt_dt         DateTime    @default(now())
  expiry_dt       DateTime
  accept_dt       DateTime?
  cancel_dt       DateTime?
  project         TbPjProject @relation(fields: [prjct_id], references: [prjct_id])

  @@map("tb_pj_project_invitation")
}

model TbPjProjectMember {
  prjct_mber_id   String      @id @default(uuid())
  prjct_id        String
  mber_id         String
  role_code       String      @default("MEMBER")
  join_dt         DateTime    @default(now())
  last_acces_dt   DateTime?
  mber_sttus_code String      @default("ACTIVE")
  sttus_chg_dt    DateTime?
  member          TbCmMember  @relation(fields: [mber_id], references: [mber_id])
  project         TbPjProject @relation(fields: [prjct_id], references: [prjct_id])

  @@unique([prjct_id, mber_id])
  @@map("tb_pj_project_member")
}

model TbPjProjectApiKey {
  api_key_id    String      @id @default(uuid())
  prjct_id      String
  provdr_nm     String
  encpt_key_val String
  mask_key_val  String
  creat_dt      DateTime    @default(now())
  mdfcn_dt      DateTime?
  project       TbPjProject @relation(fields: [prjct_id], references: [prjct_id])

  @@map("tb_pj_project_api_key")
}

model TbPjSettingsHistory {
  hist_id     String      @id @default(uuid())
  prjct_id    String
  chg_mber_id String
  chg_item_nm String
  bfr_val_cn  String?
  aftr_val_cn String?
  chg_dt      DateTime    @default(now())
  member      TbCmMember  @relation(fields: [chg_mber_id], references: [mber_id])
  project     TbPjProject @relation(fields: [prjct_id], references: [prjct_id])

  @@map("tb_pj_settings_history")
}

model TbPjMemberRemovalNotice {
  notice_id String     @id @default(uuid())
  mber_id   String
  prjct_id  String
  prjct_nm  String
  cnfrm_yn  String     @default("N")
  cnfrm_dt  DateTime?
  creat_dt  DateTime   @default(now())
  member    TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_pj_member_removal_notice")
}

model TbDsDesignChange {
  chg_id        String   @id @default(uuid())
  prjct_id      String
  ref_tbl_nm    String
  ref_id        String
  chg_rsn_cn    String?
  snapshot_data Json
  ai_req_yn     String   @default("N")
  ai_task_id    String?
  chg_mber_id   String?
  chg_dt        DateTime @default(now())

  @@map("tb_ds_design_change")
}

model TbDsUnitWork {
  unit_work_id         String          @id @default(uuid())
  prjct_id             String
  req_id               String
  unit_work_display_id String
  unit_work_nm         String          @default("")
  unit_work_dc         String?
  asign_mber_id        String?
  bgng_de              String?
  end_de               String?
  progrs_rt            Int             @default(0)
  sort_ordr            Int             @default(0)
  creat_dt             DateTime        @default(now())
  mdfcn_dt             DateTime?
  screens              TbDsScreen[]
  requirement          TbRqRequirement @relation(fields: [req_id], references: [req_id])

  @@map("tb_ds_unit_work")
}

model TbDsScreen {
  scrn_id         String                  @id @default(uuid())
  prjct_id        String
  unit_work_id    String?
  scrn_display_id String
  scrn_nm         String                  @default("")
  scrn_dc         String?
  scrn_ty_code    String                  @default("LIST")
  url_path        String?
  sort_ordr       Int                     @default(0)
  creat_dt        DateTime                @default(now())
  mdfcn_dt        DateTime?
  ctgry_l_nm      String?
  ctgry_m_nm      String?
  ctgry_s_nm      String?
  dsply_code      String?
  layer_data_dc   String?
  areas           TbDsArea[]
  unitWork        TbDsUnitWork?           @relation(fields: [unit_work_id], references: [unit_work_id])
  descHistory     TbDsScreenDescHistory[]

  @@map("tb_ds_screen")
}

model TbDsScreenDescHistory {
  hist_id     String     @id @default(uuid())
  scrn_id     String
  prjct_id    String
  bfr_dc      String?
  aftr_dc     String?
  chg_mber_id String
  creat_dt    DateTime   @default(now())
  screen      TbDsScreen @relation(fields: [scrn_id], references: [scrn_id], onDelete: Cascade)

  @@map("tb_ds_screen_desc_history")
}

model TbDsArea {
  area_id         String         @id @default(uuid())
  prjct_id        String
  scrn_id         String?
  area_display_id String
  area_nm         String         @default("")
  area_dc         String?
  area_ty_code    String         @default("GRID")
  sort_ordr       Int            @default(0)
  creat_dt        DateTime       @default(now())
  mdfcn_dt        DateTime?
  excaldw_data    Json?
  layer_data_dc   String?
  coment_cn       String?
  screen          TbDsScreen?    @relation(fields: [scrn_id], references: [scrn_id])
  functions       TbDsFunction[]

  @@map("tb_ds_area")
}

model TbDsFunction {
  func_id                String    @id @default(uuid())
  prjct_id               String
  area_id                String?
  func_display_id        String
  func_nm                String    @default("")
  func_dc                String?
  func_sttus_code        String    @default("NONE")
  priort_code            String    @default("MEDIUM")
  sort_ordr              Int       @default(0)
  creat_dt               DateTime  @default(now())
  mdfcn_dt               DateTime?
  asign_mber_id          String?
  cmplx_code             String    @default("MEDIUM")
  efrt_val               String?
  func_ty_code           String    @default("OTHER")
  impl_bgng_de           String?
  impl_end_de            String?
  coment_cn              String?
  assign_work_sttus_code String    @default("BEFORE") @db.VarChar(20)
  review_sttus_code      String    @default("BEFORE") @db.VarChar(20)
  progress_rate          Int       @default(0) @db.SmallInt
  spec_cn                String?
  area                   TbDsArea? @relation(fields: [area_id], references: [area_id])

  @@map("tb_ds_function")
}

model TbDsDbTable {
  tbl_id        String            @id @default(uuid())
  prjct_id      String
  tbl_physcl_nm String
  tbl_lgcl_nm   String?
  tbl_dc        String?
  creat_dt      DateTime          @default(now())
  columns       TbDsTableColumn[]

  @@map("tb_ds_db_table")
}

model TbDsTableColumn {
  col_id        String      @id @default(uuid())
  tbl_id        String
  col_physcl_nm String
  col_lgcl_nm   String?
  data_ty_nm    String?
  col_dc        String?
  sort_ordr     Int         @default(0)
  creat_dt      DateTime    @default(now())
  table         TbDsDbTable @relation(fields: [tbl_id], references: [tbl_id])

  @@map("tb_ds_table_column")
}

model TbDsColMapping {
  mapping_id   String    @id @default(uuid()) @db.VarChar(36)
  ref_ty_code  String    @db.VarChar(20)
  ref_id       String    @db.VarChar(36)
  col_id       String?   @db.VarChar(36)
  io_se_code   String?   @db.VarChar(10)
  ui_ty_code   String?   @db.VarChar(20)
  use_purps_cn String?   @db.VarChar(200)
  col_dc       String?
  sort_ordr    Int?      @default(0)
  creat_dt     DateTime? @default(now()) @db.Timestamp(6)

  @@map("tb_ds_col_mapping")
}

/// 공통 단계별 진척률 — 분석·설계·구현·테스트
/// ref_tbl_nm + ref_id 로 다형 참조 (단위업무, 기능, 영역 등 어디서든 사용)
model TbCmProgress {
  progrs_id     String   @id(map: "pk_cm_progress") @default(uuid()) @db.VarChar(36)
  prjct_id      String   @db.VarChar(36)
  ref_tbl_nm    String   @db.VarChar(50)
  ref_id        String   @db.VarChar(36)
  analy_rt      Int      @default(0)
  design_rt     Int      @default(0)
  impl_rt       Int      @default(0)
  test_rt       Int      @default(0)
  mdfcn_mber_id String?  @db.VarChar(36)
  mdfcn_dt      DateTime @default(now()) @db.Timestamp(6)

  @@unique([ref_tbl_nm, ref_id], map: "uk_cm_progress_ref")
  @@map("tb_cm_progress")
}

model TbAiTask {
  ai_task_id        String    @id @default(uuid())
  prjct_id          String
  ref_ty_code       String
  ref_id            String
  task_ty_code      String
  req_cn            String?
  coment_cn         String?
  result_cn         String?
  task_sttus_code   String    @default("PENDING")
  reject_rsn_cn     String?
  req_snapshot_data Json?
  parent_task_id    String?
  retry_cnt         Int       @default(3)
  exec_avlbl_dt     DateTime?
  req_mber_id       String?
  req_dt            DateTime  @default(now())
  compl_dt          DateTime?
  apply_dt          DateTime?

  @@map("tb_ai_task")
}

model TbRqTask {
  task_id         String            @id @default(uuid())
  prjct_id        String
  task_display_id String
  task_nm         String
  ctgry_code      String            @default("NEW_DEV")
  defn_cn         String?
  dtl_cn          String?
  output_info_cn  String?
  rfp_page_no     String?
  sort_ordr       Int               @default(0)
  creat_dt        DateTime          @default(now())
  mdfcn_dt        DateTime?
  requirements    TbRqRequirement[]

  @@map("tb_rq_task")
}

model TbRqRequirement {
  req_id         String          @id @default(uuid())
  prjct_id       String
  task_id        String?
  req_display_id String
  req_nm         String          @default("")
  priort_code    String          @default("MEDIUM")
  src_code       String          @default("RFP")
  rfp_page_no    String?
  orgnl_cn       String?
  curncy_cn      String?
  analy_cn       String?
  spec_cn        String?
  sort_ordr      Int             @default(0)
  creat_dt       DateTime        @default(now())
  mdfcn_dt       DateTime?
  unitWorks      TbDsUnitWork[]
  task           TbRqTask?       @relation(fields: [task_id], references: [task_id])
  userStories    TbRqUserStory[]

  @@map("tb_rq_requirement")
}

model TbRqUserStory {
  story_id           String                   @id @default(uuid())
  req_id             String
  story_display_id   String
  story_nm           String                   @default("")
  persona_cn         String?
  scenario_cn        String?
  sort_ordr          Int                      @default(0)
  creat_dt           DateTime                 @default(now())
  mdfcn_dt           DateTime?
  acceptanceCriteria TbRqAcceptanceCriteria[]
  requirement        TbRqRequirement          @relation(fields: [req_id], references: [req_id])

  @@map("tb_rq_user_story")
}

model TbRqAcceptanceCriteria {
  ac_id     String        @id @default(uuid())
  story_id  String
  given_cn  String?
  when_cn   String?
  then_cn   String?
  sort_ordr Int           @default(0)
  creat_dt  DateTime      @default(now())
  userStory TbRqUserStory @relation(fields: [story_id], references: [story_id])

  @@map("tb_rq_acceptance_criteria")
}

model TbCmAttachFile {
  attach_file_id String   @id @default(uuid())
  prjct_id       String
  ref_tbl_nm     String
  ref_id         String
  file_ty_code   String   @default("FILE")
  orgnl_file_nm  String
  stor_file_nm   String
  file_path_nm   String
  file_sz        Int
  file_extsn_nm  String
  creat_dt       DateTime @default(now())
  req_ref_yn     String?

  @@map("tb_cm_attach_file")
}

model TbRqRequirementHistory {
  req_hist_id    String   @id @default(uuid())
  req_id         String
  vrsn_no        String
  vrsn_ty_code   String   @default("INTERNAL")
  orgnl_cn       String?
  curncy_cn      String?
  spec_cn        String?
  vrsn_coment_cn String?
  chg_mber_id    String?
  creat_dt       DateTime @default(now())

  @@map("tb_rq_requirement_history")
}

model TbRqBaselineSnapshot {
  basln_id      String   @id @default(uuid())
  prjct_id      String
  basln_nm      String
  coment_cn     String?
  req_cnt       Int      @default(0)
  snapshot_data Json
  cnfrm_mber_id String?
  cnfrm_dt      DateTime @default(now())

  @@map("tb_rq_baseline_snapshot")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model tb_ai_prompt_template {
  tmpl_id        String   @id(map: "pk_ai_prompt_template") @db.VarChar(36)
  prjct_id       String?  @db.VarChar(36)
  tmpl_nm        String   @db.VarChar(200)
  task_ty_code   String   @db.VarChar(20)
  ref_ty_code    String?  @db.VarChar(20)
  sys_prompt_cn  String?
  user_prompt_cn String
  tmpl_dc        String?
  use_yn         String   @default("Y") @db.Char(1)
  sort_ordr      Int      @default(0)
  creat_mber_id  String   @db.VarChar(36)
  creat_dt       DateTime @default(now()) @db.Timestamp(6)
  mdfcn_dt       DateTime @default(now()) @db.Timestamp(6)

  @@index([prjct_id, task_ty_code, use_yn], map: "idx_ai_tmpl_prjct")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model tb_ds_review_comment {
  coment_id     String   @id(map: "pk_ds_review_comment") @db.VarChar(36)
  review_id     String   @db.VarChar(36)
  coment_cn     String
  write_mber_id String   @db.VarChar(36)
  creat_dt      DateTime @default(now()) @db.Timestamp(6)
  mdfcn_dt      DateTime @default(now()) @db.Timestamp(6)

  @@index([review_id, creat_dt], map: "idx_ds_review_coment")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model tb_ds_review_request {
  review_id         String    @id(map: "pk_ds_review_request") @db.VarChar(36)
  prjct_id          String    @db.VarChar(36)
  ref_tbl_nm        String    @db.VarChar(50)
  ref_id            String    @db.VarChar(36)
  review_title_nm   String    @db.VarChar(300)
  review_cn         String
  result_cn         String?
  req_mber_id       String    @db.VarChar(36)
  revwr_mber_id     String    @db.VarChar(36)
  review_sttus_code String    @default("REQUESTED") @db.VarChar(30)
  creat_dt          DateTime  @default(now()) @db.Timestamp(6)
  compl_dt          DateTime? @db.Timestamp(6)
  cnfrm_dt          DateTime? @db.Timestamp(6)
  mdfcn_dt          DateTime  @default(now()) @db.Timestamp(6)

  @@index([prjct_id, creat_dt(sort: Desc)], map: "idx_ds_review_prjct")
  @@index([ref_tbl_nm, ref_id], map: "idx_ds_review_ref")
  @@index([req_mber_id, review_sttus_code], map: "idx_ds_review_req_mber")
  @@index([revwr_mber_id, review_sttus_code], map: "idx_ds_review_revwr")
}
