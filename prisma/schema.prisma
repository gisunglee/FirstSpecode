// Prisma Schema — Supabase PostgreSQL 연결 설정
//
// 역할:
//   - DB 연결 설정 (Supabase PostgreSQL)
//   - 데이터 모델 정의
//
// 사용법:
//   - npm run db:push     → 스키마를 DB에 반영 (개발용)
//   - npm run db:generate → Prisma Client 재생성 (모델 추가/수정 후 필수)
//   - npm run db:studio   → 브라우저에서 DB 확인
//
// 컬럼명 규칙:
//   - DB 약어 컬럼명을 그대로 사용 (mber_id, prjct_id 등)
//   - 모든 PK는 UUID (String @default(uuid()))

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


// ==========================================
// [cm] 공통 — 회원/인증
// ==========================================

model TbCmMember {
  mber_id         String    @id @default(uuid())
  email_addr      String?   @unique
  pswd_hash       String?
  mber_nm         String?
  profl_img_url   String?
  mber_sttus_code String    @default("UNVERIFIED")
  join_dt         DateTime  @default(now())
  mdfcn_dt        DateTime?
  wthdrw_dt       DateTime?

  projectMembers      TbPjProjectMember[]
  settingsHistory     TbPjSettingsHistory[]
  emailVerifications  TbCmEmailVerification[]
  refreshTokens       TbCmRefreshToken[]
  loginAttempts       TbCmLoginAttempt[]
  accountLocks        TbCmAccountLock[]
  memberSessions      TbCmMemberSession[]
  socialAccounts      TbCmSocialAccount[]
  passwordResetTokens TbCmPasswordResetToken[]
  removalNotices      TbPjMemberRemovalNotice[]

  @@map("tb_cm_member")
}

model TbCmEmailVerification {
  vrfctn_id         String    @id @default(uuid())
  mber_id           String
  email_addr        String
  vrfctn_token_val  String    @unique
  // REGISTER / PASSWORD_RESET / EMAIL_CHANGE
  vrfctn_ty_code    String    @default("REGISTER")
  // PENDING / VERIFIED / EXPIRED
  vrfctn_sttus_code String    @default("PENDING")
  expiry_dt         DateTime
  vrfctn_dt         DateTime?
  creat_dt          DateTime  @default(now())

  member TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_email_verification")
}

model TbCmRefreshToken {
  token_id       String    @id @default(uuid())
  mber_id        String
  token_hash_val String    @unique
  // 자동 로그인 여부 — 'Y'면 토큰 갱신 시 만료 연장
  auto_login_yn  String    @default("N")
  expiry_dt      DateTime
  creat_dt       DateTime  @default(now())
  revoked_dt     DateTime?
  // 연결된 세션 ID — 로그아웃 시 해당 기기 세션만 무효화하기 위한 연결 고리
  sesn_id        String?

  member TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_refresh_token")
}

model TbCmLoginAttempt {
  attempt_id      String   @id @default(uuid())
  mber_id         String
  attempt_ip_addr String?
  // 'Y' = 성공, 'N' = 실패
  succes_yn       String   @default("N")
  fail_rsn_cn     String?
  creat_dt        DateTime @default(now())

  member TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_login_attempt")
}

model TbCmAccountLock {
  lock_id                String    @id @default(uuid())
  mber_id                String
  lock_rsn_cn            String?
  fail_cnt               Int       @default(0)
  lock_expiry_dt         DateTime?
  unlock_token_val       String?   @unique
  unlock_token_expiry_dt DateTime?
  // LOCKED / UNLOCK_PENDING / UNLOCKED
  lock_sttus_code        String    @default("LOCKED")
  creat_dt               DateTime  @default(now())
  unlocked_dt            DateTime?

  member TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_account_lock")
}

model TbCmMemberSession {
  sesn_id        String    @id @default(uuid())
  mber_id        String
  device_info_cn String?
  ip_addr        String?
  creat_dt       DateTime  @default(now())
  last_acces_dt  DateTime?
  // 로그아웃 시 무효화 일시 기록
  invald_dt      DateTime?

  member TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_member_session")
}

model TbCmPasswordResetToken {
  reset_token_id   String    @id @default(uuid())
  mber_id          String
  token_val        String    @unique
  // PENDING / USED / EXPIRED
  token_sttus_code String    @default("PENDING")
  expiry_dt        DateTime
  use_dt           DateTime?
  creat_dt         DateTime  @default(now())

  member TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_password_reset_token")
}

model TbCmSocialAccount {
  social_acnt_id    String   @id @default(uuid())
  mber_id           String
  // 'GOOGLE' 또는 'GITHUB'
  provdr_code       String
  provdr_user_id    String
  provdr_email_addr String?
  creat_dt          DateTime @default(now())

  member TbCmMember @relation(fields: [mber_id], references: [mber_id])

  // 동일 소셜 계정 중복 연동 방지
  @@unique([provdr_code, provdr_user_id])
  @@map("tb_cm_social_account")
}


// ==========================================
// [pj] 프로젝트
// ==========================================

model TbPjProject {
  prjct_id      String    @id @default(uuid())
  prjct_nm      String
  prjct_dc      String?
  client_nm     String?
  bgng_de       DateTime?
  end_de        DateTime?
  creat_mber_id String?
  creat_dt      DateTime  @default(now())
  mdfcn_dt      DateTime?

  members          TbPjProjectMember[]
  settings         TbPjProjectSettings[]
  invitations      TbPjProjectInvitation[]
  apiKeys          TbPjProjectApiKey[]
  settingsHistory  TbPjSettingsHistory[]

  @@map("tb_pj_project")
}

model TbPjProjectSettings {
  seting_id         String    @id @default(uuid())
  prjct_id          String    @unique
  ai_call_mthd_code String    @default("DIRECT")
  plan_code         String    @default("FREE")
  creat_dt          DateTime  @default(now())
  mdfcn_dt          DateTime  @default(now())

  project TbPjProject @relation(fields: [prjct_id], references: [prjct_id])

  @@map("tb_pj_project_settings")
}

model TbPjProjectInvitation {
  invt_id        String    @id @default(uuid())
  prjct_id       String
  email_addr     String
  role_code      String    @default("MEMBER")
  invt_token_val String    @unique
  invtr_mber_id  String?
  invt_sttus_code String   @default("PENDING")
  invt_dt        DateTime  @default(now())
  expiry_dt      DateTime
  accept_dt      DateTime?
  cancel_dt      DateTime?

  project TbPjProject @relation(fields: [prjct_id], references: [prjct_id])

  @@map("tb_pj_project_invitation")
}

model TbPjProjectMember {
  prjct_mber_id   String    @id @default(uuid())
  prjct_id        String
  mber_id         String
  role_code       String    @default("MEMBER")
  join_dt         DateTime  @default(now())
  last_acces_dt   DateTime?
  mber_sttus_code String    @default("ACTIVE")
  sttus_chg_dt    DateTime?

  project TbPjProject @relation(fields: [prjct_id], references: [prjct_id])
  member  TbCmMember  @relation(fields: [mber_id], references: [mber_id])

  @@unique([prjct_id, mber_id])
  @@map("tb_pj_project_member")
}

// 회원 탈퇴 시 참여 프로젝트 OWNER에게 발송되는 제거 안내
model TbPjProjectApiKey {
  api_key_id    String    @id @default(uuid())
  prjct_id      String
  provdr_nm     String
  // AES-256-CBC 암호화 저장 (iv:encrypted 형식)
  encpt_key_val String
  // 화면 표시용 마스킹 (예: sk-****1234)
  mask_key_val  String
  creat_dt      DateTime  @default(now())
  mdfcn_dt      DateTime?

  project TbPjProject @relation(fields: [prjct_id], references: [prjct_id])

  @@map("tb_pj_project_api_key")
}

model TbPjSettingsHistory {
  hist_id     String   @id @default(uuid())
  prjct_id    String
  chg_mber_id String
  chg_item_nm String
  bfr_val_cn  String?
  aftr_val_cn String?
  chg_dt      DateTime @default(now())

  project TbPjProject @relation(fields: [prjct_id], references: [prjct_id])
  member  TbCmMember  @relation(fields: [chg_mber_id], references: [mber_id])

  @@map("tb_pj_settings_history")
}

model TbPjMemberRemovalNotice {
  notice_id  String    @id @default(uuid())
  // 안내 대상: 제거된 멤버 (다음 로그인 시 모달 표시)
  mber_id    String
  prjct_id   String
  // 제거 시점의 프로젝트명 스냅샷 (프로젝트 삭제 후에도 표시 가능)
  prjct_nm   String
  // 'N': 미확인, 'Y': 확인 완료
  cnfrm_yn   String    @default("N")
  cnfrm_dt   DateTime?
  creat_dt   DateTime  @default(now())

  member TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_pj_member_removal_notice")
}


// ==========================================
// [ds] 설계 — 레이아웃 상태바에서 참조
// ==========================================

model TbDsDesignChange {
  chg_id        String   @id @default(uuid())
  prjct_id      String
  ref_tbl_nm    String
  ref_id        String
  chg_rsn_cn    String?
  snapshot_data Json
  // ai_req_yn = 'N' 인 건수 → 상태바 "미반영 설계 변경" 배지에 사용
  ai_req_yn     String   @default("N")
  ai_task_id    String?
  chg_mber_id   String?
  chg_dt        DateTime @default(now())

  @@map("tb_ds_design_change")
}


// ==========================================
// [ai] AI 태스크 — 레이아웃 상태바 AI 지표
// ==========================================

model TbAiTask {
  ai_task_id      String    @id @default(uuid())
  prjct_id        String
  ref_ty_code     String
  ref_id          String
  task_ty_code    String
  req_cn          String?
  coment_cn       String?
  result_cn       String?
  // PENDING / IN_PROGRESS / DONE / FAILED / TIMEOUT
  task_sttus_code String    @default("PENDING")
  reject_rsn_cn   String?
  req_snapshot_data Json?
  parent_task_id  String?
  retry_cnt       Int       @default(3)
  exec_avlbl_dt   DateTime?
  req_mber_id     String?
  req_dt          DateTime  @default(now())
  compl_dt        DateTime?
  apply_dt        DateTime?

  @@map("tb_ai_task")
}


// ==========================================
// [rq] 과업 / 요구사항 / 사용자스토리 / 인수기준
// ==========================================

model TbRqTask {
  task_id         String    @id @default(uuid())
  prjct_id        String
  // 표시 ID — 프로젝트 내 순번 (SFR-00001 형식)
  task_display_id String
  task_nm         String
  // NEW_DEV / IMPROVE / MAINTAIN
  ctgry_code      String    @default("NEW_DEV")
  defn_cn         String?
  dtl_cn          String?
  output_info_cn  String?
  rfp_page_no     String?
  sort_ordr       Int       @default(0)
  creat_dt        DateTime  @default(now())
  mdfcn_dt        DateTime?

  requirements TbRqRequirement[]

  @@map("tb_rq_task")
}

model TbRqRequirement {
  req_id          String    @id @default(uuid())
  prjct_id        String
  task_id         String?
  req_display_id  String
  req_nm          String    @default("")
  // HIGH / MEDIUM / LOW
  priort_code     String    @default("MEDIUM")
  // RFP / ADD / CHANGE
  src_code        String    @default("RFP")
  rfp_page_no     String?
  orgnl_cn        String?
  curncy_cn       String?
  analy_cn        String?
  spec_cn         String?
  sort_ordr       Int       @default(0)
  creat_dt        DateTime  @default(now())
  mdfcn_dt        DateTime?

  task        TbRqTask?        @relation(fields: [task_id], references: [task_id])
  userStories TbRqUserStory[]
  attachFiles TbCmAttachFile[]

  @@map("tb_rq_requirement")
}

model TbRqUserStory {
  story_id         String    @id @default(uuid())
  req_id           String
  // 표시 ID — 프로젝트 내 순번 (STR-NNNNN 형식)
  story_display_id String
  story_nm         String    @default("")
  persona_cn       String?
  scenario_cn      String?
  sort_ordr        Int       @default(0)
  creat_dt         DateTime  @default(now())
  mdfcn_dt         DateTime?

  requirement         TbRqRequirement           @relation(fields: [req_id], references: [req_id])
  acceptanceCriteria  TbRqAcceptanceCriteria[]

  @@map("tb_rq_user_story")
}

model TbRqAcceptanceCriteria {
  ac_id    String   @id @default(uuid())
  story_id String
  given_cn String?
  when_cn  String?
  then_cn  String?
  sort_ordr Int     @default(0)
  creat_dt DateTime @default(now())

  userStory TbRqUserStory @relation(fields: [story_id], references: [story_id])

  @@map("tb_rq_acceptance_criteria")
}


// ==========================================
// [cm] 공통 첨부파일
// ==========================================

model TbCmAttachFile {
  attach_file_id String   @id @default(uuid())
  prjct_id       String
  // 참조 테이블명 (e.g. 'tb_rq_requirement')
  ref_tbl_nm     String
  // 참조 레코드 ID
  ref_id         String
  // FILE / IMAGE
  file_ty_code   String   @default("FILE")
  orgnl_file_nm  String
  stor_file_nm   String
  file_path_nm   String
  file_sz        Int
  file_extsn_nm  String
  creat_dt       DateTime @default(now())

  // 요구사항 첨부파일 역참조
  requirement TbRqRequirement? @relation(fields: [ref_id], references: [req_id])

  @@map("tb_cm_attach_file")
}


// ==========================================
// [rq] 요구사항 이력 — 레이아웃 이벤트 피드
// ==========================================

model TbRqRequirementHistory {
  req_hist_id    String   @id @default(uuid())
  req_id         String
  vrsn_no        String
  // INTERNAL: 저장 시 자동 생성 / CONFIRMED: 명시적 확정
  vrsn_ty_code   String   @default("INTERNAL")
  orgnl_cn       String?
  curncy_cn      String?
  spec_cn        String?
  vrsn_coment_cn String?
  chg_mber_id    String?
  // creat_dt: 전역 생략 컬럼이지만 이벤트 피드 정렬에 필요
  creat_dt       DateTime @default(now())

  @@map("tb_rq_requirement_history")
}


// ==========================================
// [rq] 기준선 스냅샷 — 프로젝트 전체 요구사항 일괄 확정
// ==========================================

model TbRqBaselineSnapshot {
  basln_id       String   @id @default(uuid())
  prjct_id       String
  basln_nm       String
  coment_cn      String?
  // 스냅샷 시점 요구사항 수
  req_cnt        Int      @default(0)
  // 전체 요구사항 JSONB 스냅샷 (prjct_id·req_display_id·req_nm·priort_code·orgnl_cn·curncy_cn·spec_cn)
  snapshot_data  Json
  cnfrm_mber_id  String?
  cnfrm_dt       DateTime @default(now())

  @@map("tb_rq_baseline_snapshot")
}
