generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model TbCmMember {
  mber_id             String                    @id @default(uuid())
  email_addr          String?                   @unique
  pswd_hash           String?
  mber_nm             String?
  profl_img_url       String?
  mber_sttus_code     String                    @default("UNVERIFIED")
  plan_code           String                    @default("FREE") // 계정 플랜 (FREE/PRO/TEAM/ENTERPRISE)
  plan_expire_dt      DateTime? // 유료 플랜 만료일 (NULL=무료/무제한)
  asignee_view_mode   String                    @default("all") // 전역 담당자 필터 모드: all | me
  /// 시스템 역할: "SUPER_ADMIN" = 전역 관리자 / null = 일반 사용자.
  /// DB UPDATE로만 설정. UI/API 로는 변경 불가 (탈취 시 권한 연쇄 상승 차단).
  sys_role_code       String?                   @db.VarChar(20)
  join_dt             DateTime                  @default(now())
  mdfcn_dt            DateTime?
  wthdrw_dt           DateTime?
  accountLocks        TbCmAccountLock[]
  emailVerifications  TbCmEmailVerification[]
  loginAttempts       TbCmLoginAttempt[]
  memberSessions      TbCmMemberSession[]
  passwordResetTokens TbCmPasswordResetToken[]
  refreshTokens       TbCmRefreshToken[]
  socialAccounts      TbCmSocialAccount[]
  mcpKeys             TbCmMcpKey[]
  removalNotices      TbPjMemberRemovalNotice[]
  projectMembers      TbPjProjectMember[]
  settingsHistory     TbPjSettingsHistory[]
  supportSessions     TbSysAdminSupportSession[]
  adminAudits         TbSysAdminAudit[]

  @@map("tb_cm_member")
}

/// 시스템 관리자의 고객 프로젝트 지원 세션 — 읽기 전용 접근 허용.
/// 30분 자동 만료. 쓰기 API 는 이 세션이 있어도 차단됨.
model TbSysAdminSupportSession {
  sess_id       String     @id @default(uuid()) @db.VarChar(36)
  admin_mber_id String     @db.VarChar(36)
  prjct_id      String     @db.VarChar(36)
  memo          String?
  expires_dt    DateTime
  ended_dt      DateTime?
  creat_dt      DateTime   @default(now())
  admin         TbCmMember @relation(fields: [admin_mber_id], references: [mber_id])

  @@index([admin_mber_id, prjct_id, expires_dt, ended_dt], map: "idx_sys_support_sess_active")
  @@map("tb_sys_admin_support_session")
}

/// 시스템 관리자 행동 감사 로그 — 책임추적성.
/// 지원 세션 개설·전역 리소스 변경·사용자 상태 변경 등을 모두 기록.
model TbSysAdminAudit {
  audit_id      String     @id @default(uuid()) @db.VarChar(36)
  admin_mber_id String     @db.VarChar(36)
  action_type   String     @db.VarChar(40)
  target_type   String?    @db.VarChar(40)
  target_id     String?    @db.VarChar(36)
  memo          String?
  ip_addr       String?    @db.VarChar(45)
  user_agent    String?    @db.VarChar(255)
  creat_dt      DateTime   @default(now())
  admin         TbCmMember @relation(fields: [admin_mber_id], references: [mber_id])

  @@index([admin_mber_id, creat_dt(sort: Desc)], map: "idx_sys_audit_admin")
  @@index([target_type, target_id], map: "idx_sys_audit_target")
  @@map("tb_sys_admin_audit")
}

model TbCmEmailVerification {
  vrfctn_id         String     @id @default(uuid())
  mber_id           String
  email_addr        String
  vrfctn_token_val  String     @unique
  vrfctn_ty_code    String     @default("REGISTER")
  vrfctn_sttus_code String     @default("PENDING")
  expiry_dt         DateTime
  vrfctn_dt         DateTime?
  creat_dt          DateTime   @default(now())
  member            TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_email_verification")
}

model TbCmRefreshToken {
  token_id       String     @id @default(uuid())
  mber_id        String
  token_hash_val String     @unique
  auto_login_yn  String     @default("N")
  expiry_dt      DateTime
  creat_dt       DateTime   @default(now())
  revoked_dt     DateTime?
  sesn_id        String?
  member         TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_refresh_token")
}

model TbCmLoginAttempt {
  attempt_id      String     @id @default(uuid())
  mber_id         String
  attempt_ip_addr String?
  succes_yn       String     @default("N")
  fail_rsn_cn     String?
  creat_dt        DateTime   @default(now())
  member          TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_login_attempt")
}

model TbCmAccountLock {
  lock_id                String     @id @default(uuid())
  mber_id                String
  lock_rsn_cn            String?
  fail_cnt               Int        @default(0)
  lock_expiry_dt         DateTime?
  unlock_token_val       String?    @unique
  unlock_token_expiry_dt DateTime?
  lock_sttus_code        String     @default("LOCKED")
  creat_dt               DateTime   @default(now())
  unlocked_dt            DateTime?
  member                 TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_account_lock")
}

model TbCmMemberSession {
  sesn_id        String     @id @default(uuid())
  mber_id        String
  device_info_cn String?
  ip_addr        String?
  creat_dt       DateTime   @default(now())
  last_acces_dt  DateTime?
  invald_dt      DateTime?
  member         TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_member_session")
}

model TbCmPasswordResetToken {
  reset_token_id   String     @id @default(uuid())
  mber_id          String
  token_val        String     @unique
  token_sttus_code String     @default("PENDING")
  expiry_dt        DateTime
  use_dt           DateTime?
  creat_dt         DateTime   @default(now())
  member           TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_cm_password_reset_token")
}

model TbCmSocialAccount {
  social_acnt_id    String     @id @default(uuid())
  mber_id           String
  provdr_code       String
  provdr_user_id    String
  provdr_email_addr String?
  creat_dt          DateTime   @default(now())
  member            TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@unique([provdr_code, provdr_user_id])
  @@map("tb_cm_social_account")
}

model TbPjProject {
  prjct_id        String                  @id @default(uuid())
  prjct_nm        String
  prjct_dc        String?
  client_nm       String?
  bgng_de         DateTime?
  end_de          DateTime?
  creat_mber_id   String?
  creat_dt        DateTime                @default(now())
  mdfcn_dt        DateTime?
  planStudios     TbDsPlanStudio[]
  apiKeys         TbPjProjectApiKey[]
  invitations     TbPjProjectInvitation[]
  members         TbPjProjectMember[]
  settings        TbPjProjectSettings?
  settingsHistory TbPjSettingsHistory[]

  @@map("tb_pj_project")
}

model TbPjProjectSettings {
  seting_id         String      @id @default(uuid())
  prjct_id          String      @unique
  ai_call_mthd_code String      @default("DIRECT")
  plan_code         String      @default("FREE")
  creat_dt          DateTime    @default(now())
  mdfcn_dt          DateTime    @default(now())
  project           TbPjProject @relation(fields: [prjct_id], references: [prjct_id])

  @@map("tb_pj_project_settings")
}

model TbPjProjectInvitation {
  invt_id         String      @id @default(uuid())
  prjct_id        String
  email_addr      String
  role_code       String      @default("MEMBER") // OWNER/ADMIN/MEMBER/VIEWER
  job_title_code  String      @default("ETC") // PM/PL/DBA/DEV/DESIGNER/QA/ETC
  invt_token_val  String      @unique
  invtr_mber_id   String?
  invt_sttus_code String      @default("PENDING")
  invt_dt         DateTime    @default(now())
  expiry_dt       DateTime
  accept_dt       DateTime?
  cancel_dt       DateTime?
  project         TbPjProject @relation(fields: [prjct_id], references: [prjct_id])

  @@map("tb_pj_project_invitation")
}

model TbPjProjectMember {
  prjct_mber_id   String      @id @default(uuid())
  prjct_id        String
  mber_id         String
  role_code       String      @default("MEMBER") // OWNER/ADMIN/MEMBER/VIEWER (보안·접근 제어)
  job_title_code  String      @default("ETC") // PM/PL/DBA/DEV/DESIGNER/QA/ETC (직무·개인화)
  join_dt         DateTime    @default(now())
  last_acces_dt   DateTime?
  mber_sttus_code String      @default("ACTIVE")
  sttus_chg_dt    DateTime?
  member          TbCmMember  @relation(fields: [mber_id], references: [mber_id])
  project         TbPjProject @relation(fields: [prjct_id], references: [prjct_id])

  @@unique([prjct_id, mber_id])
  @@map("tb_pj_project_member")
}

// ── 시스템 기본 환경설정 템플릿 — 프로젝트 생성 시 복사 원본 ─────────────
// TbPjProjectConfig 의 "원본" 역할. 운영자가 이 테이블만 관리해 두면
// 이후 신규 프로젝트에는 복사본이 자동 생성된다.
// 주의: prjct_id=NULL 런타임 병합 방식이 아닌 "실제 복사" 패턴 — 각
//       프로젝트의 설정이 서로 완전 독립적으로 진화해야 하기 때문.
model TbSysConfigTemplate {
  sys_tmpl_id    String    @id @default(uuid())
  config_group   String    @default("GENERAL")
  config_key     String    @unique(map: "tb_sys_config_template_key_uk")
  config_label   String    @default("")
  config_dc      String?
  value_type     String    @default("TEXT")
  default_value  String    @default("")
  select_options Json?
  sort_ordr      Int       @default(0)
  use_yn         String    @default("Y")
  creat_dt       DateTime  @default(now())
  mdfcn_dt       DateTime?

  @@index([use_yn, config_group, sort_ordr], map: "tb_sys_config_template_grp_idx")
  @@map("tb_sys_config_template")
}

// ── 프로젝트 환경설정 — key-value 방식 설정 관리 ────────────────────────────
model TbPjProjectConfig {
  config_id      String    @id @default(uuid())
  prjct_id       String
  config_group   String    @default("GENERAL")
  config_key     String
  config_value   String    @default("")
  config_label   String    @default("")
  config_dc      String?
  value_type     String    @default("TEXT")
  default_value  String    @default("")
  select_options Json?
  sort_ordr      Int       @default(0)
  creat_dt       DateTime  @default(now())
  mdfcn_dt       DateTime?

  @@unique([prjct_id, config_key], map: "tb_pj_project_config_uk")
  @@index([prjct_id, config_group], map: "tb_pj_project_config_grp_idx")
  @@map("tb_pj_project_config")
}

model TbPjProjectApiKey {
  api_key_id    String      @id @default(uuid())
  prjct_id      String
  provdr_nm     String
  encpt_key_val String
  mask_key_val  String
  creat_dt      DateTime    @default(now())
  mdfcn_dt      DateTime?
  project       TbPjProject @relation(fields: [prjct_id], references: [prjct_id])

  @@map("tb_pj_project_api_key")
}

model TbPjSettingsHistory {
  hist_id     String      @id @default(uuid())
  prjct_id    String
  chg_mber_id String
  chg_item_nm String
  bfr_val_cn  String?
  aftr_val_cn String?
  chg_dt      DateTime    @default(now())
  member      TbCmMember  @relation(fields: [chg_mber_id], references: [mber_id])
  project     TbPjProject @relation(fields: [prjct_id], references: [prjct_id])

  @@map("tb_pj_settings_history")
}

model TbPjMemberRemovalNotice {
  notice_id String     @id @default(uuid())
  mber_id   String
  prjct_id  String
  prjct_nm  String
  cnfrm_yn  String     @default("N")
  cnfrm_dt  DateTime?
  creat_dt  DateTime   @default(now())
  member    TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@map("tb_pj_member_removal_notice")
}

model TbDsDesignChange {
  chg_id        String   @id @default(uuid())
  prjct_id      String
  ref_tbl_nm    String
  ref_id        String
  chg_rsn_cn    String?
  snapshot_data Json
  ai_req_yn     String   @default("N")
  ai_task_id    String?
  chg_mber_id   String?
  chg_dt        DateTime @default(now())
  chg_type_code String   @default("UPDATE")

  @@map("tb_ds_design_change")
}

model TbDsUnitWork {
  unit_work_id         String          @id @default(uuid())
  prjct_id             String
  req_id               String
  unit_work_display_id String
  unit_work_nm         String          @default("")
  unit_work_dc         String?
  asign_mber_id        String?
  bgng_de              String?
  end_de               String?
  progrs_rt            Int             @default(0)
  sort_ordr            Int             @default(0)
  creat_dt             DateTime        @default(now())
  mdfcn_dt             DateTime?
  coment_cn            String?
  screens              TbDsScreen[]
  requirement          TbRqRequirement @relation(fields: [req_id], references: [req_id])

  @@index([prjct_id], map: "tb_ds_unit_work_prjct_idx")
  @@map("tb_ds_unit_work")
}

model TbDsScreen {
  scrn_id         String        @id @default(uuid())
  prjct_id        String
  unit_work_id    String?
  scrn_display_id String
  scrn_nm         String        @default("")
  scrn_dc         String?
  scrn_ty_code    String        @default("LIST")
  url_path        String?
  asign_mber_id   String? // 담당자 회원 ID — FK 미설정(퇴장 멤버 기록 보존)
  sort_ordr       Int           @default(0)
  creat_dt        DateTime      @default(now())
  mdfcn_dt        DateTime?
  ctgry_l_nm      String?
  ctgry_m_nm      String?
  ctgry_s_nm      String?
  dsply_code      String?
  layer_data_dc   String?
  coment_cn       String?
  areas           TbDsArea[]
  unitWork        TbDsUnitWork? @relation(fields: [unit_work_id], references: [unit_work_id])

  @@index([prjct_id], map: "tb_ds_screen_prjct_idx")
  @@map("tb_ds_screen")
}

model TbDsArea {
  area_id         String         @id @default(uuid())
  prjct_id        String
  scrn_id         String?
  area_display_id String
  area_nm         String         @default("")
  area_dc         String?
  area_ty_code    String         @default("GRID")
  sort_ordr       Int            @default(0)
  creat_dt        DateTime       @default(now())
  mdfcn_dt        DateTime?
  excaldw_data    Json?
  layer_data_dc   String?
  coment_cn       String?
  screen          TbDsScreen?    @relation(fields: [scrn_id], references: [scrn_id])
  functions       TbDsFunction[]

  @@index([prjct_id], map: "tb_ds_area_prjct_idx")
  @@map("tb_ds_area")
}

model TbDsFunction {
  func_id         String    @id @default(uuid())
  prjct_id        String
  area_id         String?
  func_display_id String
  func_nm         String    @default("")
  func_dc         String?
  priort_code     String    @default("MEDIUM")
  sort_ordr       Int       @default(0)
  creat_dt        DateTime  @default(now())
  mdfcn_dt        DateTime?
  asign_mber_id   String?
  cmplx_code      String    @default("MEDIUM")
  efrt_val        String?
  func_ty_code    String    @default("OTHER")
  impl_bgng_de    String?
  impl_end_de     String?
  coment_cn       String?
  area            TbDsArea? @relation(fields: [area_id], references: [area_id])

  @@index([prjct_id], map: "tb_ds_function_prjct_idx")
  @@map("tb_ds_function")
}

model TbDsDbTable {
  tbl_id        String              @id @default(uuid())
  prjct_id      String
  tbl_physcl_nm String
  tbl_lgcl_nm   String?
  tbl_dc        String?
  asign_mber_id String?                                // 담당자 회원 ID — FK 미설정(퇴장 멤버 기록 보존)
  creat_dt      DateTime            @default(now())
  mdfcn_mber_id String?
  mdfcn_dt      DateTime?           @db.Timestamp(3)
  columns       TbDsDbTableColumn[]

  @@index([prjct_id], map: "tb_ds_db_table_prjct_idx")
  @@map("tb_ds_db_table")
}

model TbDsDbTableColumn {
  col_id        String      @id @default(uuid())
  tbl_id        String
  col_physcl_nm String
  col_lgcl_nm   String?
  data_ty_nm    String?
  col_dc        String?
  ref_grp_code  String?     @db.VarChar(100) // 참조 공통코드 그룹코드 (tb_cm_code_group.grp_code)
  sort_ordr     Int         @default(0)
  creat_dt      DateTime    @default(now())
  mdfcn_mber_id String?
  mdfcn_dt      DateTime?   @db.Timestamp(3)
  table         TbDsDbTable @relation(fields: [tbl_id], references: [tbl_id])

  @@map("tb_ds_db_table_column")
}

/// DB 테이블/컬럼 변경 이력 (감사 기록용)
///   - 한 번의 저장 요청 = 한 revision (여러 컬럼 변경을 묶음)
///   - snapshot_data: { table:{before,after}, columns:{added[],modified[],removed[]} }
///   - chg_summary: "컬럼 3개 추가, 1개 수정" 같은 자동 생성 요약
///   - AI/사람 구분 없음 (시킨 사람의 chg_mber_id 에 기록)
model TbDsDbTableRevision {
  rev_id        String   @id @default(uuid())
  prjct_id      String
  tbl_id        String
  rev_no        Int // 해당 테이블 내 순번 (1부터)
  chg_type_code String // CREATE | UPDATE | DELETE
  chg_summary   String? // 자동 생성 요약
  snapshot_data Json // diff 스냅샷
  chg_mber_id   String?
  chg_dt        DateTime @default(now())

  @@index([tbl_id, chg_dt(sort: Desc)], map: "idx_db_tbl_rev_tbl")
  @@index([prjct_id, chg_dt(sort: Desc)], map: "idx_db_tbl_rev_prjct")
  @@map("tb_ds_db_table_revision")
}

model TbDsColMapping {
  mapping_id   String    @id @default(uuid()) @db.VarChar(36)
  ref_ty_code  String    @db.VarChar(20)
  ref_id       String    @db.VarChar(36)
  col_id       String?   @db.VarChar(36)
  io_se_code   String?   @db.VarChar(10)
  ui_ty_code   String?   @db.VarChar(20)
  use_purps_cn String?   @db.VarChar(200)
  col_dc       String?
  sort_ordr    Int?      @default(0)
  creat_dt     DateTime? @default(now()) @db.Timestamp(6)

  @@map("tb_ds_col_mapping")
}

/// 공통 단계별 진척률 — 분석·설계·구현·테스트
/// ref_tbl_nm + ref_id 로 다형 참조 (단위업무, 기능, 영역 등 어디서든 사용)
model TbCmProgress {
  progrs_id     String   @id(map: "pk_cm_progress") @default(uuid()) @db.VarChar(36)
  prjct_id      String   @db.VarChar(36)
  ref_tbl_nm    String   @db.VarChar(50)
  ref_id        String   @db.VarChar(36)
  analy_rt      Int      @default(0)
  design_rt     Int      @default(0)
  impl_rt       Int      @default(0)
  test_rt       Int      @default(0)
  mdfcn_mber_id String?  @db.VarChar(36)
  mdfcn_dt      DateTime @default(now()) @db.Timestamp(6)

  @@unique([ref_tbl_nm, ref_id], map: "uk_cm_progress_ref")
  @@map("tb_cm_progress")
}

model TbAiTask {
  ai_task_id        String             @id @default(uuid())
  prjct_id          String
  ref_ty_code       String
  ref_id            String
  task_ty_code      String
  req_cn            String?
  coment_cn         String?
  result_cn         String?
  task_sttus_code   String             @default("PENDING")
  reject_rsn_cn     String?
  req_snapshot_data Json?
  parent_task_id    String?
  retry_cnt         Int                @default(0)
  exec_avlbl_dt     DateTime?
  req_mber_id       String?
  req_dt            DateTime           @default(now())
  compl_dt          DateTime?
  apply_dt          DateTime?
  implSnapshots     TbSpImplSnapshot[]

  @@map("tb_ai_task")
}

model TbRqTask {
  task_id         String            @id @default(uuid())
  prjct_id        String
  task_display_id String
  task_nm         String
  ctgry_code      String            @default("NEW_DEV")
  defn_cn         String?
  dtl_cn          String?
  output_info_cn  String?
  rfp_page_no     String?
  asign_mber_id   String? // 담당자 회원 ID — FK 미설정(퇴장 멤버 기록 보존)
  sort_ordr       Int               @default(0)
  creat_dt        DateTime          @default(now())
  mdfcn_dt        DateTime?
  requirements    TbRqRequirement[]

  @@index([prjct_id], map: "tb_rq_task_prjct_idx")
  @@map("tb_rq_task")
}

model TbRqRequirement {
  req_id         String          @id @default(uuid())
  prjct_id       String
  task_id        String?
  req_display_id String
  req_nm         String          @default("")
  priort_code    String          @default("MEDIUM")
  src_code       String          @default("RFP")
  rfp_page_no    String?
  orgnl_cn       String?
  curncy_cn      String?
  analy_cn       String?
  spec_cn        String?
  asign_mber_id  String? // 담당자 회원 ID — FK 미설정(퇴장 멤버 기록 보존)
  sort_ordr      Int             @default(0)
  creat_dt       DateTime        @default(now())
