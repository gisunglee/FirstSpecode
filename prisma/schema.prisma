// ── MCP 키 — Claude Code 등 외부 AI 클라이언트의 인바운드 인증용 ─────────
// prjct_id = 'ALL'  → 전역 키 (해당 사용자가 ACTIVE 멤버인 모든 프로젝트 접근 가능)
// prjct_id = UUID   → 프로젝트 단위 scope 고정 (다른 프로젝트 접근 시 403 FORBIDDEN_SCOPE)
//
// fail-secure 설계:
//   - NOT NULL (@default 없음) → INSERT 시 반드시 명시 지정 (누락 시 DB 오류)
//   - 'ALL' 명시적 sentinel → null 의존이 없어져 "실수로 전역 권한" 사고 차단
//   - tb_pj_project FK 없음 → 'ALL'이 실제 프로젝트가 아니라 FK 불가. 대신 프로젝트
//     삭제 시 scope 키는 멤버십 조회에서 403 되므로 무해화됨(app 레이어 보호).
//
// 원문은 저장하지 않고 SHA-256 해시만 저장 (spk_ prefix + 32B 랜덤 hex).
// NOTE: tb_pj_project_api_key(외부 AI provider 키 보관소)와 혼동 금지 — 용도/저장방식 다름.
model TbCmMcpKey {
  api_key_id   String    @id @default(uuid())
  mber_id      String
  prjct_id     String                        // 'ALL' 또는 UUID — NOT NULL, no default

  // [2026-04-26] 키 용도 구분 — Claude Code MCP / 워커 인증 채널 분리
  //   CLIENT — Claude Code MCP 도구용 (전역/프로젝트 scope 모두 허용)
  //   WORKER — /run-ai-tasks 워커용 (프로젝트 scope 강제, 전역 발급 거부)
  // CHECK 제약(prisma/sql/2026-04-26_add_mcp_key_use_se_code.sql)으로
  // 두 값 외에는 INSERT 자체 차단된다.
  key_use_se_code String    @default("CLIENT") @db.VarChar(20)

  key_hash     String    @unique
  key_prefix   String    @db.VarChar(12)
  key_nm       String    @db.VarChar(100)
  last_used_dt DateTime?
  revoke_dt    DateTime?
  creat_dt     DateTime  @default(now())

  member  TbCmMember @relation(fields: [mber_id], references: [mber_id])

  @@index([mber_id],                              map: "idx_mcp_key_mber")
  @@index([prjct_id],                             map: "idx_mcp_key_prjct")
  @@index([mber_id, key_use_se_code, revoke_dt], map: "idx_mcp_key_use_se")
  @@map("tb_cm_mcp_key")
}

// Rate Limit 카운터 — 인증 엔드포인트(로그인/가입/재설정/토큰갱신) 남용 방어용.
// Fixed Window Counter: src/lib/rateLimit.ts 의 checkRateLimit 헬퍼에서 upsert.
// 키 포맷: "<ENDPOINT>_<DIMENSION>:<value>" (예: LOGIN_IP:1.2.3.4)
