# Supabase 연결 설정
# Supabase 대시보드 → Settings → Database → Connection string (URI 방식) 복사
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Supabase Direct URL (마이그레이션용 — connection pooler 우회)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# 사용 방법:
#   1. 이 파일을 .env.local 로 복사
#   2. 실제 값으로 교체
#   3. .env.local 은 .gitignore 에 포함되어 있으므로 커밋되지 않음
